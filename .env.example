# https://nexty.dev/docs/start-project/enviroment

# -----------------------------------------------------------------------------
# Site info (required)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_PRICING_PATH="/#pricing"
NEXT_PUBLIC_LOCALE_DETECTION=false
NEXT_PUBLIC_OPTIMIZED_IMAGES=false
# Login mode options: page (redirect to login), dialog (popup login dialog)
NEXT_PUBLIC_LOGIN_MODE=dialog
NEXT_PUBLIC_COOKIE_CONSENT_ENABLED="false"
NEXT_PUBLIC_USER_SOURCE_TRACKING_ENABLED="true"
NEXT_PUBLIC_RATE_LIMIT_ENABLED="false"
NEXT_PUBLIC_EMAIL_NORMALIZATION_ENABLED="false"

#------------------------------------------------------------------------
# Database
# https://nexty.dev/docs/integration/database
#------------------------------------------------------------------------
DATABASE_URL=""

#------------------------------------------------------------------------
# Auth - better-auth
# Generate BETTER_AUTH_SECRET using `openssl rand -base64 32`
# https://nexty.dev/docs/integration/auth
#------------------------------------------------------------------------
BETTER_AUTH_SECRET=""
NEXT_PUBLIC_GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

#------------------------------------------------------------------------
# Cloudflare Turnstile
# https://nexty.dev/docs/integration/auth
#------------------------------------------------------------------------
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

#------------------------------------------------------------------------
# Resend
# https://nexty.dev/docs/integration/resend
# https://nexty.dev/docs/integration/domain-email
#------------------------------------------------------------------------
RESEND_API_KEY=
ADMIN_EMAIL=
ADMIN_NAME=

#------------------------------------------------------------------------
# Upstash
# https://nexty.dev/docs/integration/upstash
#------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

#------------------------------------------------------------------------
# stripe
# API Docs: https://docs.stripe.com/api
# https://nexty.dev/docs/integration/stripe
#------------------------------------------------------------------------
NEXT_PUBLIC_DEFAULT_CURRENCY=usd
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Subscription Management Page
STRIPE_CUSTOMER_PORTAL_URL=/dashboard/subscription
# Stripe Radar Early Fraud Warning Response Configuration
# Controls the automatic response when Stripe Radar detects potential fraud (radar.early_fraud_warning.created event)
# Options:
#   - "refund,email": Automatically refund the fraudulent charge AND send email notification to admin
#   - "refund": Only automatically refund the fraudulent charge
#   - "email": Only send email notification to admin (no automatic refund)
# Leave empty or unset to disable automatic fraud response
STRIPE_RADAR_EARLY_FRAUD_WARNING_TYPE=refund,email


#------------------------------------------------------------------------
# creem
# API Docs: https://docs.creem.io/
#------------------------------------------------------------------------
CREEM_API_BASE_URL=https://api.creem.io/v1
CREEM_API_KEY=
CREEM_WEBHOOK_SECRET=

#------------------------------------------------------------------------
# Cloudflare R2
# https://nexty.dev/docs/integration/cloudflare-r2
#------------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# R2_PUBLIC_URL should start with 'https://' 
R2_PUBLIC_URL=

#------------------------------------------------------------------------
# AI
# OpenAI: https://platform.openai.com/docs/overview
# DeepSeek: https://api-docs.deepseek.com/
# Anthropic: https://docs.anthropic.com/en/docs/welcome
# Grok: https://docs.x.ai/docs/overview
# Gemini: https://ai.google.dev/gemini-api/docs
# Replicate: https://replicate.com/
# fal.ai: https://fal.ai/docs
# Firecrawl: https://www.firecrawl.dev/
#------------------------------------------------------------------------
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
REPLICATE_API_TOKEN=
# Replicate webhook signature verification secret
# Get from: https://replicate.com/docs/webhooks#signing-secrets
REPLICATE_WEBHOOK_SIGNING_SECRET=
OPENROUTER_API_KEY=
# fal.ai API key (auto-detected by @fal-ai/client)
FAL_KEY=
# Set to "true" to enable fal.ai webhook signature verification
FAL_VERIFY_WEBHOOKS=false
FIRECRAWL_API_KEY=

#------------------------------------------------------------------------
# Translate
# route: /api/admin/translate
# support providers: openai, deepseek, anthropic, xai, google
#------------------------------------------------------------------------
NEXT_PUBLIC_AI_MODEL_ID=
NEXT_PUBLIC_AI_PROVIDER=

# -----------------------------------------------------------------------------
# Analytics & Ads
# Docs: https://nexty.dev/docs/integration/tracking
# -----------------------------------------------------------------------------
# Google
NEXT_PUBLIC_GOOGLE_ID=
NEXT_PUBLIC_GOOGLE_ADSENSE_ID=
# Clarity
NEXT_PUBLIC_CLARITY_PROJECT_ID=
# Plausible
NEXT_PUBLIC_PLAUSIBLE_SRC=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
PLAUSIBLE_API_KEY=
PLAUSIBLE_URL=
# Umami
NEXT_PUBLIC_UMAMI_SRC=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
# Rybbit
NEXT_PUBLIC_RYBBIT_SRC=
NEXT_PUBLIC_RYBBIT_SITE_ID=
NEXT_PUBLIC_RYBBIT_SESSION_REPLAY="true"
NEXT_PUBLIC_RYBBIT_REPLAY_MASK_SELECTORS='[".user-name", "#email"]'
# Posthog
NEXT_PUBLIC_POSTHOG_HOST=
NEXT_PUBLIC_POSTHOG_KEY=

# ---
# Customer Support
# Crisp: 
# ----
NEXT_PUBLIC_CRISP_WEBSITE_ID=

# -----------------------------------------------------------------------------
# Discord
# -----------------------------------------------------------------------------
NEXT_PUBLIC_DISCORD_INVITE_URL=""
DISCORD_WEBHOOK_URL=""

# ---
# Tolt.io(Affiliates): https://app.tolt.io/
# ---
NEXT_PUBLIC_TOLT_ID=